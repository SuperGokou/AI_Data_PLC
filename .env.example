# App
APP_ENV=development
SERVER_PORT=8080
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
JWT_SECRET=change-me-at-least-32-characters
ENCRYPTION_KEY=change-me-at-least-32-characters

# Default realtime target. Requirement default is 5 seconds and can be tuned later.
PLC_REALTIME_DELAY_SECONDS=5

# AI control mode:
# OFF | RECOMMEND_ONLY | SIMULATION | APPROVAL_REQUIRED | AUTO_DISPATCH
AI_CONTROL_MODE=RECOMMEND_ONLY
AI_CONTROL_WRITE_ENABLED=false
AI_CONTROL_DRY_RUN=true
AI_CONTROL_REQUIRE_HUMAN_APPROVAL=true
AI_CONTROL_ALLOWED_ACTIONS=READ_STATUS,SUGGEST_SETPOINT
AI_CONTROL_BLOCKED_ACTIONS=PLC_WRITE,PUMP_START,VALVE_OPEN,RESET_ESTOP
AI_CONTROL_AUDIT_LOG_ENABLED=true
AI_CONTROL_SAFE_STATE_ON_ERROR=true
AI_CONTROL_HMAC_SECRET=

# Database
MYSQL_DATABASE=ai_data_plc
MYSQL_USER=plc
MYSQL_PASSWORD=plc_dev_password
MYSQL_ROOT_PASSWORD=root_dev_password
MYSQL_HOST=mysql
MYSQL_PORT=3306

# InfluxDB
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=supergokou
INFLUXDB_BUCKET=plc_timeseries
INFLUXDB_TOKEN=dev-influx-token-change-me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# LLM / industrial algorithm providers. Leave keys blank unless enabled.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_NAME=deepseek-reasoner

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL_NAME=qwen-plus

GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=
GLM_MODEL_NAME=glm-4-plus

MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_API_KEY=
MINIMAX_MODEL_NAME=abab6.5s-chat

OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL_NAME=

# Deployment
RENDER_API_KEY=
